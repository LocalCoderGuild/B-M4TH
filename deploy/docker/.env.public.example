# Public origin where users open the web UI.
PUBLIC_BASE_URL=https://game.example.com

# Allowed browser origin for server-side CORS.
CLIENT_ORIGIN=https://game.example.com

# Host port bindings.
WEB_EXPOSE_PORT=80
ENGINE_EXPOSE_PORT=2567
API_EXPOSE_PORT=2566

# Optional explicit images/tags (override defaults in docker-compose.prod.yml).
# SERVER_IMAGE=ghcr.io/siraphat-ohm/b-m4th-server:latest
# WEB_IMAGE=ghcr.io/siraphat-ohm/b-m4th-web:latest
