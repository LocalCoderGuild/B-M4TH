# Public origin where users open the web UI.
PUBLIC_BASE_URL=http://xxx.x.xxx.xx

# Allowed browser origin for server-side CORS.
CLIENT_ORIGIN=http://xxx.x.xxx.xx

# Colyseus WebSocket URL baked into web build.
VITE_ENGINE_URL=ws://xxx.x.xxx.xx:2567
# HTTP REST API URL baked into web build.
VITE_API_URL=http://xxx.x.xxx.xx:2566
# Web public URL baked into web build.
VITE_PUBLIC_URL=http://xxx.x.xxx.xx

# Host port bindings.
WEB_EXPOSE_PORT=80
ENGINE_EXPOSE_PORT=2567
API_EXPOSE_PORT=2566
